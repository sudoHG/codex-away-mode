#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

find_python_runtime() {
  local candidate
  for candidate in python3 python; do
    if command -v "$candidate" >/dev/null 2>&1; then
      if "$candidate" -c 'import sys; raise SystemExit(0 if sys.version_info[0] == 3 else 1)' >/dev/null 2>&1; then
        command -v "$candidate"
        return 0
      fi
    fi
  done
  return 1
}

if ! RUNTIME="$(find_python_runtime)"; then
  if [[ " $* " == *" --json "* ]]; then
    printf '{"ok":false,"failed_code":"runtime_missing","user_message":"还缺一个本地运行环境。这个 Skill 需要 Python 3 或 uv 来运行本地通知程序。","agent_next_step":"Install Python 3 or uv, then rerun codex-away-mode install."}\n'
  else
    printf 'Codex Away Mode needs Python 3 or uv to run.\n' >&2
  fi
  exit 1
fi

export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH:-}"
exec "$RUNTIME" -m codex_away_mode "$@"
